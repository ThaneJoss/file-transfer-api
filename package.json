{
  "name": "file-transfer-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "r2:cors:apply": "wrangler r2 bucket cors set \"$R2_BUCKET\" --file config/r2-cors.json --force",
    "r2:cors:list": "wrangler r2 bucket cors list \"$R2_BUCKET\"",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "cf-typegen": "wrangler types worker-configuration.d.ts --include-runtime=false",
    "db:generate": "drizzle-kit generate",
    "db:migrations:list:local": "wrangler d1 migrations list file-transfer-api-db --local",
    "db:migrations:list:remote": "wrangler d1 migrations list file-transfer-api-db --remote",
    "db:migrations:apply:local": "wrangler d1 migrations apply file-transfer-api-db --local",
    "db:migrations:apply:remote": "wrangler d1 migrations apply file-transfer-api-db --remote"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.19",
    "@better-auth/passkey": "1.6.19",
    "better-auth": "^1.6.19",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.17",
    "@cloudflare/workers-types": "^4.20260619.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
