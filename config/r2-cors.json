{
  "rules": [
    {
      "allowed": {
        "origins": ["https://file.thanejoss.com"],
        "methods": ["GET", "PUT"],
        "headers": [
          "Authorization",
          "Content-Type",
          "x-amz-content-sha256",
          "x-amz-date",
          "x-amz-security-token"
        ]
      },
      "exposeHeaders": ["ETag", "Content-Length", "Content-Type"],
      "maxAgeSeconds": 3600
    }
  ]
}
